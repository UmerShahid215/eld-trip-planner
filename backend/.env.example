# --- Django ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated. Include your backend host once deployed.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.onrender.com

# --- Database ---
# Local dev falls back to SQLite if unset. In production use Postgres:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# --- CORS (the frontend origin[s]) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
# CORS_ALLOW_ALL_ORIGINS=False

# --- Routing / geocoding ---
# Free key from https://openrouteservice.org/dev/#/signup (driving-hgv profile).
ORS_API_KEY=
# Nominatim requires a real User-Agent identifying your app (usage policy).
NOMINATIM_USER_AGENT=eld-trip-planner/1.0 (contact: you@example.com)
# OSRM demo fallback (no key). Some old TLS stacks need http for the demo host.
# OSRM_URL=https://router.project-osrm.org/route/v1/driving
# Degrade to a labelled straight-line estimate if all providers are unreachable.
ENABLE_ESTIMATE_FALLBACK=True
ROUTING_TIMEOUT=20
